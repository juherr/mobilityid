{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":disableRateLimiting",
    ":rebaseStalePrs"
  ],
  "timezone": "Europe/Paris",
  "labels": [
    "dependencies"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github-actions"
    },
    {
      "matchManagers": ["sbt"],
      "matchPackageNames": ["scala"],
      "allowedVersions": "/^(2\\.|3\\.3\\.|3\\.([89]|[1-9][0-9])\\.)/"
    },
    {
      "matchManagers": ["sbt"],
      "matchPackageNames": ["!scala"],
      "groupName": "scala-sbt"
    },
    {
      "matchManagers": [
        "gradle"
      ],
      "groupName": "gradle"
    },
    {
      "matchDepNames": ["java"],
      "extractVersion": "^openjdk-(?<version>\\d+)"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)mise\\.toml$/"
      ],
      "matchStrings": [
        "(?<depName>[A-Za-z0-9_.-]+)\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "asdf",
      "versioningTemplate": "loose",
      "extractVersion": "^(?:openjdk-)?(?<version>\\d+\\.\\d+)"
    }
  ]
}
