{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":disableRateLimiting",
    ":rebaseStalePrs"
  ],
  "timezone": "Europe/Paris",
  "labels": [
    "dependencies"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github-actions",
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "matchManagers": ["sbt"],
      "matchPackageNames": ["scala"],
      "allowedVersions": "/^(2\\.|3\\.3\\.|3\\.([89]|[1-9][0-9])\\.)/"
    },
    {
      "matchManagers": ["sbt"],
      "matchPackageNames": ["!scala"],
      "groupName": "scala-sbt"
    },
    {
      "matchManagers": [
        "gradle"
      ],
      "groupName": "gradle"
    },
    {
      "matchManagers": [
        "npm"
      ],
      "groupName": "typescript-npm"
    },
    {
      "matchManagers": [
        "npm"
      ],
      "matchDepTypes": [
        "devDependencies"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "matchManagers": [
        "gomod"
      ],
      "groupName": "go-modules"
    },
    {
      "matchManagers": [
        "custom.regex"
      ],
      "matchDepNames": ["java"],
      "extractVersion": "^openjdk-(?<version>\\d+)"
    },
    {
      "matchFileNames": [
        "php/composer.json"
      ],
      "matchDepTypes": [
        "require-dev"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "groupName": "php-dependencies",
      "automerge": true,
      "automergeType": "branch"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)mise\\.toml$/"
      ],
      "matchStrings": [
        "(?<depName>[A-Za-z0-9_.-]+)\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "asdf",
      "versioningTemplate": "loose",
      "extractVersion": "^(?:openjdk-)?(?<version>\\d+(?:\\.\\d+)?)"
    }
  ]
}
