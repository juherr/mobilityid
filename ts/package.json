{
  "name": "@juherr/mobilityid",
  "version": "0.0.0-development",
  "description": "TypeScript mobility ID domain model, validation, and parsers",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "packageManager": "bun@1.3.12",
  "engines": {
    "node": ">=22",
    "bun": ">=1.3.12"
  },
  "scripts": {
    "build": "vp pack",
    "lint": "vp lint",
    "format": "vp fmt . --write",
    "format:check": "vp fmt --check",
    "typecheck": "vp check",
    "test": "vp test",
    "license:check": "vp exec eslint \"src/**/*.ts\" \"test/**/*.ts\" --max-warnings 0",
    "license:apply": "vp exec eslint \"src/**/*.ts\" \"test/**/*.ts\" --fix",
    "check": "vp check && vp test && bun run license:check && vp pack"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript-eslint/parser": "^8.26.0",
    "eslint": "^9.22.0",
    "eslint-plugin-header": "^3.1.1",
    "vite-plus": "^0.1.16"
  }
}
