{
    "name": "juherr/mobility-id",
    "description": "Mobility ID PHP Library",
    "type": "library",
    "require": {
        "php": "^8.3",
        "league/iso3166": "^4.4"
    },
    "autoload": {
        "psr-4": {
            "Juherr\\MobilityId\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Juherr\\MobilityId\\Tests\\": "tests/"
        }
    },
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "Julien Herr",
            "email": "contact@juherr.dev"
        }
    ],
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.0",
        "phpstan/extension-installer": "^1.4"
    },
    "config": {
        "platform": {
            "php": "8.3.0"
        },
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "scripts": {
        "format": "./vendor/bin/php-cs-fixer fix --ansi --using-cache=no",
        "format:check": "./vendor/bin/php-cs-fixer fix --ansi --using-cache=no --dry-run --diff",
        "analyse": "./vendor/bin/phpstan analyse",
        "test": "./vendor/bin/phpunit",
        "check": [
            "@format:check",
            "@analyse",
            "@test"
        ]
    }
}
